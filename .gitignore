# ========================
# PQC-MQTT .gitignore
# ========================

# --- Build Artifacts ---
build/
out/
*.o
*.a
*.so
*.dylib
*.dll
*.exe
*.out

# --- CMake ---
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json
install_manifest.txt
CTestTestfile.cmake

# --- Generated PKI ---
pki/output/

# --- Evaluation Results ---
eval/results/raw/
eval/results/figures/
eval/results/tables/

# --- Third-party sources and compiled outputs (cloned/built during build) ---
toolchain/_vendor/
toolchain/_install/

# --- Packet captures ---
*.pcap
*.pcapng

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

env/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Logs ---
*.log
